# Copy to scripts/prod.env (gitignored) and fill in. aws-bootstrap.sh feeds
# these to the App Runner service as runtime environment variables.
#
# For real secrets, prefer AWS Secrets Manager over plaintext here; this file is
# the quick path to a working service. S3_BUCKET must match the one in
# aws-bootstrap.sh.
# Paste your managed Postgres connection string (e.g. from Neon — neon.tech).
# Keep CREATE_RDS unset/false to use this. Set CREATE_RDS=true only to have the
# bootstrap script provision RDS instead, in which case it overwrites this line.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/cats?sslmode=require
SECRET_KEY=change-me-run-secrets-token_hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
S3_BUCKET=cats-media-prod
S3_REGION=us-east-1
MEDIA_BASE_URL=
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
