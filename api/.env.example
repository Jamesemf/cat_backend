DATABASE_URL=sqlite:///./cats.db
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Leave S3_BUCKET empty to store media on local disk (dev). Set it to enable S3.
S3_BUCKET=
S3_REGION=us-east-1
# Public base for media URLs (e.g. a CloudFront domain). Empty => presigned S3
# URLs in prod, or the API's /uploads route in local dev.
MEDIA_BASE_URL=

# Anthropic API key for Claude Haiku vision recognition.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sonnet 4.6 is the default — best accuracy/cost tradeoff for vision.
# Swap to claude-haiku-4-5-20251001 (cheap, lower quality) or claude-opus-4-7
# (top quality, ~5× Sonnet cost) if your needs change.
ANTHROPIC_MODEL=claude-sonnet-4-6
